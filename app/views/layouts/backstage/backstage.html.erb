<!DOCTYPE html>
<html>
  <head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">
    <title><%= Rails.application.class.module_parent_name.humanize %> — Backstage Admin</title>
    <%= csrf_meta_tags %>
    <%= stylesheet_link_tag "backstage/pico", media: "all" %>
    <%= stylesheet_link_tag "backstage/backstage", media: "all" %>
    <script>
      document.addEventListener("DOMContentLoaded", function() {
        document.querySelectorAll("[data-confirm-message]").forEach(function(btn) {
          btn.addEventListener("click", function(e) {
            if (!window.confirm(btn.dataset.confirmMessage)) {
              e.preventDefault()
            }
          })
        })
        document.querySelectorAll("[data-multi-select-search]").forEach(function(input) {
          input.addEventListener("input", function() {
            var q = input.value.toLowerCase()
            input.closest("[data-multi-select]")
                 .querySelectorAll("[data-multi-select-item]")
                 .forEach(function(item) {
                   item.hidden = q.length > 0 && !item.textContent.toLowerCase().includes(q)
                 })
          })
        })
        document.addEventListener("click", function(e) {
          var destroyBtn = e.target.closest("[data-nested-destroy]")
          if (destroyBtn) {
            var row = destroyBtn.closest("tr")
            var flag = row.querySelector("[data-nested-destroy-flag]")
            if (flag) flag.value = "1"
            row.hidden = true
          }
          var addBtn = e.target.closest("[data-nested-add]")
          if (addBtn) {
            var table = addBtn.closest("table")
            var tmpl = table.querySelector("[data-nested-template]")
            var index = parseInt(tmpl.dataset.nextIndex, 10)
            tmpl.dataset.nextIndex = index + 1
            var html = tmpl.innerHTML.replace(/__INDEX__/g, index)
            addBtn.closest("tr").insertAdjacentHTML("beforebegin", html)
          }
        })
      })
    </script>
  </head>
  <body>
    <header>
      <%= link_to "Admin Home", backstage.root_path %>
    </header>
    <nav>
      <ul>
        <% nav_resources.each do |config| %>
          <li><%= link_to config.model_class.model_name.human.pluralize,
                          resources_path(resource: config.model_name_param) %></li>
        <% end %>
      </ul>
    </nav>
    <main>
      <%= yield %>
    </main>
  </body>
</html>
